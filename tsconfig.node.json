{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node"],
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"composite": true,
		"declaration": true,
		"outDir": "./dist-node"
	},
	"include": ["vite.config.ts", "vitest.config.ts"]
}
