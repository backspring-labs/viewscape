{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noExcessiveCognitiveComplexity": "warn"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useConsistentArrayType": {
					"level": "error",
					"options": { "syntax": "shorthand" }
				},
				"useImportType": "error",
				"useExportType": "error",
				"noDefaultExport": "error"
			},
			"suspicious": {
				"noConsoleLog": "error",
				"noExplicitAny": "error"
			}
		}
	},
	"overrides": [
		{
			"include": ["vite.config.ts", "vitest.config.ts", "src/main.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"include": ["*.stories.tsx", ".storybook/**"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"include": ["src/**/*.test.{ts,tsx}"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsoleLog": "off"
					}
				}
			}
		}
	],
	"files": {
		"ignore": ["node_modules", "dist", "dist-node", "coverage", "storybook-static"]
	}
}
